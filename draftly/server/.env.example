# Server
PORT=3000
SESSION_SECRET=your_session_secret_here

# MongoDB
MONGO_URI=mongodb://localhost:27017/draftly

# Google OAuth2
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Google Gemini API (free tier — get key at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# Token encryption key — AES-256-GCM (32 bytes as 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here
